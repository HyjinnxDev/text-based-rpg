generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Auth (Better Auth compatible)
// ---------------------------------------------------------------------------

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?
  role          UserRole @default(PLAYER)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  accounts         Account[]
  sessions         Session[]
  hostedCampaigns  Campaign[]       @relation("CampaignHost")
  campaignMembers  CampaignMember[]
  characters       Character[]
  playerKnowledge  PlayerKnowledge[]
  campaignEvents   CampaignEvent[]  @relation("EventActor")
  pendingActions   PendingAction[]
  aiProviderConfigs AiProviderConfig[]
  aiUsageLogs      AiUsageLog[]
}

enum UserRole {
  ADMIN
  PLAYER
}

model Account {
  id                    String   @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@map("account")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verification")
}

// ---------------------------------------------------------------------------
// Campaigns
// ---------------------------------------------------------------------------

enum CampaignStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum CampaignMode {
  SOLO
  PARTY
  SHARED_WORLD
}

enum GenerationMode {
  RANDOM
  ROUGH_IDEA
  CUSTOM
}

enum CampaignMemberRole {
  HOST
  PLAYER
  OBSERVER
}

model Campaign {
  id             String           @id @default(cuid())
  hostUserId     String
  title          String
  premise        String?
  status         CampaignStatus   @default(DRAFT)
  mode           CampaignMode     @default(SOLO)
  generationMode GenerationMode?
  tone           String?
  genre          String?
  settings       Json             @default("{}")
  worldTime      Json             @default("{\"day\":1,\"hour\":8,\"season\":\"spring\",\"calendarLabel\":\"Day 1, Spring\"}")
  worldState     Json             @default("{}")
  maxPlayers     Int              @default(8)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  archivedAt     DateTime?

  host            User              @relation("CampaignHost", fields: [hostUserId], references: [id], onDelete: Cascade)
  members         CampaignMember[]
  characters      Character[]
  npcs            Npc[]
  locations       Location[]
  mapMarkers      MapMarker[]
  items           Item[]
  quests          Quest[]
  factions        Faction[]
  codexEntries    CodexEntry[]
  events          CampaignEvent[]
  scenes          Scene[]
  playerKnowledge PlayerKnowledge[]
  pendingActions  PendingAction[]
  snapshots       CampaignSnapshot[]
  aiUsageLogs     AiUsageLog[]

  @@index([hostUserId])
  @@index([status])
}

model CampaignMember {
  id         String             @id @default(cuid())
  campaignId String
  userId     String
  role       CampaignMemberRole @default(PLAYER)
  joinedAt   DateTime           @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([campaignId, userId])
  @@index([campaignId])
}

model CampaignSnapshot {
  id           String   @id @default(cuid())
  campaignId   String
  label        String
  snapshotData Json
  isManual     Boolean  @default(false)
  createdAt    DateTime @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
}

// ---------------------------------------------------------------------------
// Event sourcing
// ---------------------------------------------------------------------------

model CampaignEvent {
  id          String   @id @default(cuid())
  campaignId  String
  sequence    Int
  eventType   String
  actorUserId String?
  sceneId     String?
  payload     Json     @default("{}")
  stateDelta  Json?
  inWorldTime Json?
  createdAt   DateTime @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  actor    User?    @relation("EventActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  scene    Scene?   @relation(fields: [sceneId], references: [id], onDelete: SetNull)

  @@unique([campaignId, sequence])
  @@index([campaignId])
}

model PendingAction {
  id         String              @id @default(cuid())
  campaignId String
  userId     String
  sceneId    String?
  status     PendingActionStatus @default(PENDING)
  intent     Json
  aiTaskType String?
  retryCount Int                 @default(0)
  lastError  String?
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  scene    Scene?   @relation(fields: [sceneId], references: [id], onDelete: SetNull)

  @@index([campaignId])
  @@index([status])
}

enum PendingActionStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

// ---------------------------------------------------------------------------
// Scenes (multiplayer-first domain concept)
// ---------------------------------------------------------------------------

enum SceneScope {
  PUBLIC
  PARTY
  PRIVATE
  EXCLUSIVE
  INSTANCED
}

enum SceneStatus {
  ACTIVE
  PAUSED
  CLOSED
}

model Scene {
  id         String      @id @default(cuid())
  campaignId String
  scope      SceneScope  @default(PARTY)
  locationId String?
  title      String
  status     SceneStatus @default(ACTIVE)
  metadata   Json        @default("{}")
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  campaign     Campaign            @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  location     Location?           @relation(fields: [locationId], references: [id], onDelete: SetNull)
  participants SceneParticipant[]
  events       CampaignEvent[]
  pendingActions PendingAction[]

  @@index([campaignId])
}

model SceneParticipant {
  id          String  @id @default(cuid())
  sceneId     String
  userId      String?
  characterId String?
  npcId       String?
  role        String  @default("player")

  scene     Scene      @relation(fields: [sceneId], references: [id], onDelete: Cascade)
  character Character? @relation(fields: [characterId], references: [id], onDelete: SetNull)
  npc       Npc?       @relation(fields: [npcId], references: [id], onDelete: SetNull)

  @@index([sceneId])
}

// ---------------------------------------------------------------------------
// Player knowledge (information ownership)
// ---------------------------------------------------------------------------

model PlayerKnowledge {
  id            String   @id @default(cuid())
  campaignId    String
  userId        String
  knowledgeKey  String
  category      String
  content       Json     @default("{}")
  visibility    Json     @default("{\"scope\":\"private\"}")
  sourceEventId String?
  learnedAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([campaignId, userId, knowledgeKey])
  @@index([campaignId, userId])
}

// ---------------------------------------------------------------------------
// World entities
// ---------------------------------------------------------------------------

model Character {
  id                String   @id @default(cuid())
  campaignId        String
  userId            String?
  isPlayerCharacter Boolean  @default(true)
  name              String
  profile           Json     @default("{}")
  stats             Json     @default("{}")
  visualProfile     Json?
  portraitUrl       String?
  locationId        String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  campaign     Campaign           @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  user         User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  location     Location?          @relation(fields: [locationId], references: [id], onDelete: SetNull)
  participants SceneParticipant[]

  @@index([campaignId])
  @@index([userId])
}

model Npc {
  id            String   @id @default(cuid())
  campaignId    String
  name          String
  personality   Json     @default("{}")
  memory        Json     @default("{\"events\":[]}")
  relationships Json     @default("{}")
  visualProfile Json?
  portraitUrl   String?
  locationId    String?
  status        Json     @default("{\"alive\":true}")
  schedule      Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  campaign     Campaign           @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  location     Location?          @relation(fields: [locationId], references: [id], onDelete: SetNull)
  participants SceneParticipant[]

  @@index([campaignId])
}

model Location {
  id               String   @id @default(cuid())
  campaignId       String
  parentLocationId String?
  name             String
  mapLevel         String   @default("region")
  description      String?
  coordinates      Json?
  metadata         Json     @default("{}")
  discoveryState   Json     @default("{\"discovered\":false}")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  campaign   Campaign    @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  parent     Location?   @relation("LocationHierarchy", fields: [parentLocationId], references: [id], onDelete: SetNull)
  children   Location[]  @relation("LocationHierarchy")
  characters Character[]
  npcs       Npc[]
  items      Item[]
  mapMarkers MapMarker[]
  scenes     Scene[]

  @@index([campaignId])
}

model MapMarker {
  id         String   @id @default(cuid())
  campaignId String
  locationId String?
  markerType String
  entityId   String?
  label      String
  position   Json
  visibility Json     @default("{\"scope\":\"party\"}")
  metadata   Json     @default("{}")
  updatedAt  DateTime @updatedAt

  campaign Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  location Location? @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@index([campaignId])
}

model Item {
  id          String   @id @default(cuid())
  campaignId  String
  name        String
  description String?
  category    String
  quantity    Int      @default(1)
  properties  Json     @default("{}")
  ownerType   String
  ownerId     String
  locationId  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  campaign Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  location Location? @relation(fields: [locationId], references: [id], onDelete: SetNull)

  @@index([campaignId])
  @@index([ownerType, ownerId])
}

model Quest {
  id          String   @id @default(cuid())
  campaignId  String
  title       String
  description String?
  status      String   @default("active")
  threadType  String   @default("side")
  objectives  Json     @default("[]")
  visibility  Json     @default("{\"scope\":\"party\"}")
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
}

model Faction {
  id          String   @id @default(cuid())
  campaignId  String
  name        String
  description String?
  standing    Json     @default("{}")
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
}

model CodexEntry {
  id          String   @id @default(cuid())
  campaignId  String
  category    String
  slug        String
  title       String
  content     Json     @default("{}")
  visibility  Json     @default("{\"scope\":\"party\"}")
  isStale     Boolean  @default(false)
  needsReview Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, slug])
  @@index([campaignId, category])
}

// ---------------------------------------------------------------------------
// AI configuration
// ---------------------------------------------------------------------------

enum AiProvider {
  MOCK
  OPENAI
  ANTHROPIC
  GOOGLE
}

model AiProviderConfig {
  id                String     @id @default(cuid())
  userId            String
  provider          AiProvider
  encryptedApiKey   String?
  enabled           Boolean    @default(true)
  defaultTextModel  String?
  defaultImageModel String?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
}

model AiUsageLog {
  id                 String     @id @default(cuid())
  userId             String
  campaignId         String?
  taskType           String
  provider           AiProvider
  model              String
  inputTokens        Int?
  outputTokens       Int?
  estimatedCostCents Int?
  success            Boolean
  errorMessage       String?
  createdAt          DateTime   @default(now())

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaign Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([campaignId])
}
