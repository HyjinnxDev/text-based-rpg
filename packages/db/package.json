{
  "name": "@tbrpg/db",
  "version": "0.1.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "generate": "dotenv -e ../../.env -- prisma generate",
    "migrate": "dotenv -e ../../.env -- prisma migrate deploy",
    "migrate:dev": "dotenv -e ../../.env -- prisma migrate dev",
    "push": "dotenv -e ../../.env -- prisma db push",
    "push:ci": "prisma db push --skip-generate",
    "studio": "dotenv -e ../../.env -- prisma studio",
    "build": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^6.8.2"
  },
  "devDependencies": {
    "dotenv-cli": "^8.0.0",
    "prisma": "^6.8.2",
    "typescript": "^5.8.3"
  },
  "prisma": {
    "schema": "prisma/schema.prisma"
  }
}
