# Database
DATABASE_URL=postgresql://tbrpg:tbrpg@localhost:5432/tbrpg

# Redis
REDIS_URL=redis://localhost:6379

# Better Auth
BETTER_AUTH_SECRET=dev-secret-change-in-production-use-openssl-rand
BETTER_AUTH_URL=http://localhost:3000

# Object storage
# local = filesystem (auto /tmp on Vercel; ephemeral across instances)
# blob = Vercel Blob (recommended on Vercel — add Blob store in dashboard)
# s3 = MinIO / S3-compatible
STORAGE_DRIVER=local
LOCAL_STORAGE_PATH=.storage
# STORAGE_DRIVER=s3
# S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=tbrpg-assets
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true

# Text / chat LLM (campaign generation, scene narration, state deltas)
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Image generation only — maps, landscapes, character/NPC portraits (Gemini Nano Banana)
GEMINI_KEY=
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
# Alias for GEMINI_KEY
GOOGLE_GENERATIVE_AI_API_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_REALTIME_URL=http://localhost:3001
NEXT_PUBLIC_MAPLIBRE_STYLE=https://demotiles.maplibre.org/style.json

# Realtime service
REALTIME_PORT=3001
# Set true for dev without worker; false in production (use worker queue)
REALTIME_INLINE_RESOLVE=true
