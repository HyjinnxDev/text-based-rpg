# Database
DATABASE_URL=postgresql://tbrpg:tbrpg@localhost:5432/tbrpg

# Redis
REDIS_URL=redis://localhost:6379

# Better Auth
BETTER_AUTH_SECRET=dev-secret-change-in-production-use-openssl-rand
BETTER_AUTH_URL=http://localhost:3000

# Object storage (MinIO in Docker; use local filesystem without Docker)
STORAGE_DRIVER=local
LOCAL_STORAGE_PATH=.storage
# STORAGE_DRIVER=s3
# S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=tbrpg-assets
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true

# AI providers (mock used when no keys; GEMINI_KEY alone selects google)
AI_PROVIDER=mock
GEMINI_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Alias for GEMINI_KEY (Vercel Google AI integration)
GOOGLE_GENERATIVE_AI_API_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_REALTIME_URL=http://localhost:3001
NEXT_PUBLIC_MAPLIBRE_STYLE=https://demotiles.maplibre.org/style.json

# Realtime service
REALTIME_PORT=3001
# Set true for dev without worker; false in production (use worker queue)
REALTIME_INLINE_RESOLVE=true
